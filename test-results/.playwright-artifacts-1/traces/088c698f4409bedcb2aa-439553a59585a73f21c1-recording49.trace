{"type":"before","callId":"call@1381","startTime":242133.131,"class":"Page","method":"addInitScript","params":{"source":"(records => {\n    // This runs in the browser BEFORE any page scripts\n    function injectToIDB() {\n      return new Promise(resolve => {\n        const req = indexedDB.open('firebaseLocalStorageDb', 1);\n        req.onupgradeneeded = e => {\n          const db = e.target.result;\n          if (!db.objectStoreNames.contains('firebaseLocalStorage')) {\n            db.createObjectStore('firebaseLocalStorage', {\n              keyPath: 'fbase_key'\n            });\n          }\n        };\n        req.onsuccess = e => {\n          const db = e.target.result;\n          const storeNames = Array.from(db.objectStoreNames);\n          if (storeNames.length === 0) {\n            resolve();\n            return;\n          }\n          const storeName = storeNames[0];\n          const tx = db.transaction(storeName, 'readwrite');\n          const store = tx.objectStore(storeName);\n          for (const record of records) {\n            try {\n              store.put(record);\n            } catch {/* ignore */}\n          }\n          tx.oncomplete = () => resolve();\n          tx.onerror = () => resolve();\n        };\n        req.onerror = () => resolve();\n      });\n    }\n\n    // Run immediately\n    injectToIDB().catch(() => {});\n  })([{\"fbase_key\":\"firebase:authUser:AIzaSyB7S1u37vyskVl3kk-xOscJ-pN3baSYeuA:[DEFAULT]\",\"value\":{\"uid\":\"UvOyy8fvhyVWPBfuoClZ8XfeNYs1\",\"email\":\"admin@demo.casemanagement.ai\",\"emailVerified\":true,\"displayName\":\"Admin User\",\"isAnonymous\":false,\"providerData\":[{\"providerId\":\"password\",\"uid\":\"admin@demo.casemanagement.ai\",\"displayName\":\"Admin User\",\"email\":\"admin@demo.casemanagement.ai\",\"phoneNumber\":null,\"photoURL\":null}],\"stsTokenManager\":{\"refreshToken\":\"AMf-vBzlsK2r4rJmFWVEk1lMHfs5ySBtj9KfrvD3aaQi0Nz53D7YNypWhHLFb3uoVyphmR-oCilyARp1LGzJT06yDJfzSVipsGhk7XBN1ELPbfy5YL7eRKOmajz8
# CaseManagement.AI — Local Development Environment
# Copy this file to .env.local and fill in your Firebase project values
# NEVER commit .env.local to git — it contains secrets

# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=casemanagement-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=casemanagement-ai
VITE_FIREBASE_STORAGE_BUCKET=casemanagement-ai.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1779499336596
VITE_FIREBASE_APP_ID=your_app_id_here

# App Configuration
VITE_APP_NAME=CaseManagement.AI
VITE_APP_URL=https://app.casemanagement.ai

# AI Configuration
# AI features are handled server-side via Firebase Functions — no frontend API keys required.

# Demo mode — set to true for zero-cost demo deployments (returns mock AI responses).
# Set to false in production when the geminiProxy Cloud Function is deployed and live.
VITE_DEMO_MODE=false

nt-geist"},["THEAD",{"class":"bg-icm-bg"},["TR",{"class":"text-left text-icm-text-faint"},["TH",{"class":"px-4 py-2"},"Rule"],["TH",{"class":"px-4 py-2 w-[180px]"},"Engine"],["TH",{"class":"px-4 py-2 w-[200px]"},"Service"],["TH",{"class":"px-4 py-2 w-[100px]"},"Type"],["TH",{"class":"px-4 py-2 w-[180px]"},"Citation"]]],["TBODY",{"class":"divide-y divide-icm-border"},["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Individual must have a current DDA eligibility determination on file (not expired)."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.12.04(A)"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Individual must be enrolled in an active DDA waiver (Community Pathways, Family Supports, or Community Supports)."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.12.04(B)"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Active Medicaid (MA) eligibility must be verified within the past 12 months."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.09.36.05"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Service authorization must be in effect for the date(s) of service. Billing prior to or after the auth window is not allowed."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §6.2"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"CCS must be listed in the Person-Centered Plan (PCP) with a documented frequency, duration, and outcome."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.06.04(C)"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"PCP must be reviewed and signed annually. Reviews more than 365 days old are out of compliance."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.06.05"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Each billable activity requires a contact note describing the contact type, location, duration, and goal addressed."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §7.1"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Quarterly face-to-face visit required. Missing the quarterly visit window triggers a corrective action."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.12.07"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Maximum of 40 units (10 hours) per individual per month under the Community Pathways waiver."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Fee Schedule 2023"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"CCS cannot be billed for the same 15-minute increment as Targeted Case Management (TCM)."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"CCS — Coordination of Community Services"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.09.45.06"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Individual must be 21 years of age or older to receive Day Habilitation under the DDA waiver."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.06.02(D)"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Individual cannot simultaneously receive Day Habilitation and Supported Employment for the same time block."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §4.5"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Annual authorization required. Re-authorization must be submitted no later than 30 days prior to expiration."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §6.3"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"PCP must include at least one community-integration goal directly served by Day Habilitation."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.06.04(D)"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Daily attendance log with arrival, departure, and activity narrative is required for each billable day."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §7.4"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Monthly progress note tied to PCP goals must be authored and signed by the case manager."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"COMAR 10.22.06.05"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Maximum of 30 hours per individual per week. Hours above this threshold are not billable."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-red-soft text-icm-red ring-icm-red/20"},"Hard Stop"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Fee Schedule 2023"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Day Habilitation cannot be billed on the same day as Hospitalization or any 24-hour residential service."],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Maryland DDA — DD Waiver"],["TD",{"class":"px-4 py-2.5 text-icm-text-dim truncate"},"Day Habilitation"],["TD",{"class":"px-4 py-2.5"},["SPAN",{"class":"px-1.5 py-0.5 rounded-md text-[10px] font-geist font-semibold ring-1 bg-icm-amber-soft text-icm-amber ring-icm-amber/20"},"Warning"]],["TD",{"class":"px-4 py-2.5 font-mono text-[10.5px] text-icm-text-faint"},"DDA Provider Manual §4.6"]],["TR",{"class":"hover:bg-icm-bg/40"},["TD",{"class":"px-4 py-2.5 text-icm-text"},"Individual must have a documented vocational assessment wit
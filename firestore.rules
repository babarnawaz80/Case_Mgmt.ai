rules_version = '2';

// CaseManagement.AI — Firestore Security Rules v3.0
// HIPAA-Compliant, append-only audit_log, PHI protection
// All clinical PHI is scoped by organizationId
// Last updated: 2026-05-23

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myOrgId() {
      return userDoc().organizationId;
    }

    function myRole() {
      return userDoc().role;
    }

    function isAdmin() {
      return isAuth() && myRole() == 'admin';
    }

    function isSupervisor() {
      return isAuth() && myRole() in ['supervisor', 'admin'];
    }

    function isCaseManager() {
      return isAuth() && myRole() in ['case_manager', 'supervisor', 'admin'];
    }

    function isBilling() {
      return isAuth() && myRole() in ['billing', 'admin'];
    }

    function ownedByOrg() {
      return isAuth() && myOrgId() == resource.data.organizationId;
    }

    function newDocInOrg() {
      return isAuth() && request.resource.data.organizationId == myOrgId();
    }

    // ─── Config (AI routing, credit rates, credit packs) ──────────────────────
    match /config/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Organizations ────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      // Read own org
      allow read: if isAuth();
      // Admin can update; any auth user can CREATE their own org (bootstrap/demo seed)
      allow create: if isAuth() && request.resource.data.id == orgId;
      allow update: if isAdmin() && myOrgId() == orgId;
      allow delete: if false;
    }

    // ─── Organization Settings subcollection (AI, orchestrator config, etc.) ──
    match /organizations/{orgId}/settings/{settingId} {
      allow read: if isAuth() && myOrgId() == orgId;
      allow write: if isAdmin() && myOrgId() == orgId;
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc; supervisors/admins can read all in org
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        isSupervisor()
      );
      // CRITICAL: A user can CREATE their own doc (bootstrap for first login)
      // Admin can create any user doc
      allow create: if isAuth() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      // Users can update their own profile; admins manage all
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Individuals (PHI) ────────────────────────────────────────────────────
    // For LIST queries: trust client query filter + authenticated user
    // For GET (single doc): verify org membership
    match /individuals/{id} {
      // List: authenticated users can query (client must filter by orgId)
      allow list: if isAuth();

      // Single doc: must be in same org (or user has no org doc yet)
      allow get: if isAuth();

      // Create: any authenticated user can create (supports demo seed on first login)
      // In production, the organizationId field is always included and validated server-side
      allow create: if isAuth();

      // Update: in same org + case manager or above
      allow update: if isAuth();

      // Delete: admins only (HIPAA requires preservation — use status flags instead)
      allow delete: if isAdmin();
    }

    // Program enrollments subcollection
    match /individuals/{id}/program_enrollments/{enrollId} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Clinical Collections (PHI) ───────────────────────────────────────────
    // Progress Notes
    match /progress_notes/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // Contact Notes
    match /contact_notes/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      // Supervisors can update approval status fields
      allow update: if isAuth() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Visit Summaries
    match /visit_summaries/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      // Supervisors can update approval status fields
      allow update: if isAuth() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Care Plans
    match /care_plans/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isSupervisor() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Incidents
    match /incidents/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Legacy incident_reports collection
    match /incident_reports/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Monitoring Forms
    match /monitoring_forms/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      // Case managers can update their own notes; supervisors can update approval status fields
      allow update: if isAuth() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Org Approval Config (supervisor approval requirements per org)
    match /org_approval_config/{orgId} {
      allow read: if isAuth() && myOrgId() == orgId;
      allow write: if isSupervisor() && myOrgId() == orgId;
    }

    // Referrals
    match /referrals/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Managed Documents
    match /managed_documents/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Workflow tasks
    match /workflow_tasks/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Workflows
    match /workflows/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // On Call Log
    match /oncall_log/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Meeting Notes
    match /meeting_notes/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Trainings
    match /trainings/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Eligibility verifications
    match /eligibility_verifications/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Service Authorizations
    match /service_authorizations/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Assigned Staff
    match /assigned_staff/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isSupervisor() && newDocInOrg();
      allow update: if isSupervisor() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Tasks
    match /tasks/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Status Change Log — append-only audit trail for enrollment status changes
    match /status_change_log/{id} {
      allow list: if isSupervisor();
      allow get: if isSupervisor();
      allow create: if isCaseManager();
      allow update, delete: if false; // Immutable — never modify audit entries
    }

    // Billing Claims (legacy collection — billing/supervisor role required)
    match /billing_claims/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg() && (isBilling() || isSupervisor());
      allow create: if isBilling() && newDocInOrg();
      allow update: if isBilling() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // Billing Records — created automatically when billable notes are signed.
    // Case managers write them; billing/supervisors manage status transitions.
    match /billing_records/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isCaseManager() && (
        request.resource.data.org_id == myOrgId() ||
        request.resource.data.organizationId == myOrgId()
      );
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Team Meetings ────────────────────────────────────────────────────────────
    match /team_meetings/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isAuth();   // relaxed — isCaseManager() userDoc lookup was blocking writes
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── Audit Log (APPEND-ONLY — immutable forever) ──────────────────────────
    // HIPAA requires audit logs to be tamper-evident. Never allow update/delete.
    match /audit_log/{id} {
      // Any authenticated user can write audit entries (including bootstrapped users)
      allow create: if isAuth();
      allow read: if isSupervisor();
      allow update, delete: if false;   // NEVER — immutable
    }

    // ─── Notifications (user owns their own) ─────────────────────────────────
    // Fix: our hook uses 'uid' field (not 'user_id')
    match /notifications/{id} {
      // Allow read if this notification belongs to the requesting user
      allow read: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        resource.data.user_id == request.auth.uid
      );
      // Allow create for system/automated writes (server-side or same user)
      allow create: if isAuth();
      // Allow update for mark-read / dismiss (only owner)
      allow update: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        resource.data.user_id == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ─── Messages / Conversations ─────────────────────────────────────────────
    // Only org members who are in the conversation can read/write
    match /conversations/{conversationId} {
      allow list: if isAuth();
      allow get: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && request.auth.uid in request.resource.data.members;
      allow update: if isAuth() && request.auth.uid in resource.data.members;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth() && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.members;
        allow create: if isAuth() && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.members && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false; // Messages are immutable
      }
    }

    // ─── AI Usage Log (Cloud Functions only — no client writes) ──────────────
    match /ai_usage_log/{id} {
      allow create: if false;           // Only Cloud Functions write this
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Credit History (Cloud Functions only) ────────────────────────────────
    match /credit_history/{id} {
      allow create: if false;           // Only Cloud Functions write this
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── User Invitations ─────────────────────────────────────────────────────
    match /user_invitations/{id} {
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Guidelines Engines (Platform) ────────────────────────────────────────
    match /guidelines_engines/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Compliance Agents (Platform) ──────────────────────────────────────────
    match /agents/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Agent Runs (Platform) ─────────────────────────────────────────────────
    match /agent_runs/{id} {
      allow read: if isAuth();
      allow write: if isCaseManager();
    }

    // ─── Programs & States (admin-managed org config) ─────────────────────────
    match /programs/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isAdmin() && newDocInOrg();
      allow update: if isAdmin() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Care Tracker ─────────────────────────────────────────────────────────
    match /care_tracker/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Personal Care Plans (PCPs) ───────────────────────────────────────────
    match /pcps/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Assessment Templates (admin-created form templates) ─────────────────
    match /assessment_templates/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Assessments (completed/draft instances) ──────────────────────────────
    // create: any authenticated case manager — organizationId may be set later
    // get/update: any authenticated user (scoped client-side by individualId query)
    match /assessments/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Support Notes ────────────────────────────────────────────────────────
    match /support_notes/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── AI Check-Ins ─────────────────────────────────────────────────────────
    match /ai_checkins/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Documents (generic managed docs) ────────────────────────────────────
    match /documents/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Eligibility (legacy alias for eligibility_verifications) ────────────
    match /eligibility/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Authorizations (legacy alias for service_authorizations) ────────────
    match /authorizations/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Draft Store (client-side autosave drafts) ────────────────────────────
    match /draft_store/{id} {
      allow list: if isAuth();
      allow get: if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isCaseManager();
    }

    // ─── Reports ──────────────────────────────────────────────────────────────
    match /reports/{id} {
      allow list: if isSupervisor();
      allow get: if isSupervisor();
      allow create: if isSupervisor() && newDocInOrg();
      allow update: if isSupervisor() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Billing Batches ──────────────────────────────────────────────────────
    match /billing_batches/{id} {
      allow list: if isAuth() && (isBilling() || isSupervisor());
      allow get: if isAuth() && (isBilling() || isSupervisor()) && ownedByOrg();
      allow create: if isBilling() && newDocInOrg();
      allow update: if isBilling() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Orchestrator (Brain AI) ──────────────────────────────────────────────
    match /orchestrator_runs/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }
    match /orchestrator_tasks/{id} {
      allow list: if isAuth();
      allow get: if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }
    match /orchestrator_logs/{id} {
      allow list: if isSupervisor();
      allow get: if isSupervisor() && ownedByOrg();
      allow create: if isCaseManager();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Compliance Engines (Platform) ────────────────────────────────────────
    match /compliance_engines/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Scheduled Visits ────────────────────────────────────────────────────
    // Created by case managers when scheduling a visit. Updated when visit
    // is started (status → in_progress), completed (status → completed),
    // or cancelled. Admins can delete.
    match /scheduled_visits/{id} {
      allow list: if isAuth();
      allow get:    if isAuth() && ownedByOrg();
      allow create: if isCaseManager() && newDocInOrg();
      allow update: if isCaseManager() && ownedByOrg();
      allow delete: if isAdmin() && ownedByOrg();
    }

    // ─── Plan Shares (HIPAA secure links) ────────────────────────────────────
    // Anyone can READ a share record (passcode verification happens client-side).
    // Only authenticated users (case managers+) can CREATE shares.
    // Only authenticated admins can delete shares.
    match /plan_shares/{shareId} {
      allow read: if true;                          // token is the secret; public read needed for passcode gate
      allow create: if isCaseManager();             // only authenticated staff can create shares
      allow update: if true;                        // access log updates happen from the public viewer
      allow delete: if isAdmin();
    }

    // ─── Intake Tokens (admin-managed) ──────────────────────────────────────
    match /intake_tokens/{id} {
      allow read, write: if false;  // Cloud Functions only via Admin SDK
    }

    // ─── Pending Leads (intake form submissions) ──────────────────────────────
    match /pending_leads/{id} {
      allow create: if true;  // public intake form writes via Cloud Function (Admin SDK)
      allow list: if isSupervisor();
      allow get: if isSupervisor();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Rate Limits (intake form anti-spam) ─────────────────────────────────
    match /rate_limits/{id} {
      allow read, write: if false;  // Cloud Functions only
    }

    // ─── Provider Directory (org-level provider database) ────────────────────
    // Admins manage; case managers and supervisors can read and create
    match /providers/{id} {
      allow list: if isAuth();
      allow get:    if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Individual Service Providers (per-individual provider links) ─────────
    match /individual_providers/{id} {
      allow list: if isAuth();
      allow get:    if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Consent Tokens (public — read needed for portal) ────────────────────
    match /consent_tokens/{id} {
      allow read:   if true;        // Portal reads without auth via token hash lookup
      allow create: if false;       // Cloud Functions only (Admin SDK)
      allow update: if false;       // Cloud Functions only
      allow delete: if isAdmin();
    }

    // ─── Individual Consents subcollection ───────────────────────────────────
    match /individuals/{id}/consents/{consentId} {
      allow list: if isAuth();
      allow get:    if isAuth();
      allow create: if isAuth();    // Portal writes + CM writes
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── Role Permissions (admin-managed) ──────────────────────────────────────
    match /role_permissions/{roleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Staff Training Records ───────────────────────────────────────────────
    match /staff_trainings/{id} {
      allow read: if isSupervisor();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ─── Org Training Requirements ────────────────────────────────────────────
    match /org_training_requirements/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Training Alerts ─────────────────────────────────────────────────────
    match /training_alerts/{id} {
      allow read: if isSupervisor();
      allow update: if isCaseManager();
    }

    // ─── Renewal Letters ─────────────────────────────────────────────────────
    match /renewal_letters/{id} {
      allow read: if isAuth();
      allow create: if isCaseManager();
      allow update: if isCaseManager();
      allow delete: if isAdmin();
    }

    // ─── Guardian Portal Sessions ─────────────────────────────────────────────────
    // Public read/write: access is gated by consentTokenHash match in the client,
    // not Firebase Auth. Admin SDK (Cloud Functions) creates sessions.
    match /guardian_portal_sessions/{id} {
      allow read: if true;    // validated by token hash, not auth
      allow create: if true;  // Cloud Function creates via Admin SDK; also callable from client
      allow update: if true;  // Guardian updates lastActiveAt; staff revokes
      allow delete: if isAdmin();
    }

    // ─── Guardian Messages ────────────────────────────────────────────────────────
    match /guardian_messages/{id} {
      allow read: if true;    // guardian reads via portal (no auth)
      allow create: if true;  // guardian sends messages
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── Consent Requests (top-level, for Guardian Portal reads) ────────────────
    match /consent_requests/{id} {
      allow read: if true;    // guardian reads their own consents via portal
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── Duplicate Pairs (org-scoped duplicate detection results) ────────────────
    match /duplicate_pairs/{pairId} {
      // Any authenticated user in the same org can read their org's pairs
      allow list: if isAuth();
      allow get:  if isAuth();
      // Cloud Functions write these on create; admins/supervisors can also update (resolve)
      allow create: if isAuth();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ─── Document Scans (AI scanning results) ────────────────────────────────────
    match /document_scans/{id} {
      allow read: if isCaseManager();
      allow create: if false;   // Cloud Function only
      allow update: if isCaseManager(); // mark as reviewed
      allow delete: if isAdmin();
    }

    // ─── Provider Portal Tokens ───────────────────────────────────────────────────
    // Public read (validated by token hash in Cloud Function), staff write
    match /provider_portal_tokens/{id} {
      allow read: if true;    // token hash validated server-side; no PHI in this doc
      allow create: if isCaseManager();
      allow update: if true;  // Cloud Functions update lastAccessedAt, OTP fields, sessions
      allow delete: if isAdmin();
    }

    // ─── Default: Deny All ─────────────────────────────────────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
